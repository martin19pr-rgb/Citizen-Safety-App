
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Critical medical and vehicle information for the citizen.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "bloodType": { "type": "string" },
        "allergies": { "type": "string" },
        "vehiclePlate": { "type": "string" },
        "spouseName": { "type": "string" },
        "secondaryContactName": { "type": "string" },
        "secondaryContactPhone": { "type": "string" },
        "photoUrl": { "type": "string" },
        "level": { "type": "number", "description": "Security clearance level" }
      },
      "required": ["name", "bloodType"]
    },
    "SafetyIncident": {
      "title": "Safety Incident",
      "description": "A logged emergency incident triggered by SOS or Voice.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["police", "ambulance", "fire", "security", "medical", "help", "manual_sos"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["dispatched", "resolved", "cancelled"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document identified by Firebase Auth UID."
    },
    "/incidents/{incidentId}": {
      "schema": "SafetyIncident",
      "description": "Global log of all safety incidents for dispatch monitoring."
    }
  }
}
