
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Critical medical and vehicle information for the citizen.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "bloodType": { "type": "string" },
        "allergies": { "type": "string" },
        "vehiclePlate": { "type": "string" },
        "spouseName": { "type": "string" },
        "secondaryContactName": { "type": "string" },
        "secondaryContactPhone": { "type": "string" },
        "photoUrl": { "type": "string" },
        "level": { "type": "number", "description": "Security clearance level" }
      },
      "required": ["name", "bloodType"]
    },
    "SafetyIncident": {
      "title": "Safety Incident",
      "description": "The unified Single Source of Truth for all emergency responses.",
      "type": "object",
      "properties": {
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["ACTIVE", "ENROUTE", "RESOLVED", "CANCELLED"] },
        "priority": { "type": "string", "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "citizen": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" }
          }
        },
        "media": {
          "type": "object",
          "properties": {
            "videoUrl": { "type": "string" },
            "audioUrl": { "type": "string" }
          }
        },
        "ai": {
          "type": "object",
          "properties": {
            "threatLevel": { "type": "string" },
            "objects": { "type": "array", "items": { "type": "string" } },
            "confidence": { "type": "number" }
          }
        },
        "assignedOfficer": { "type": "string", "nullable": true },
        "visibility": {
          "type": "object",
          "properties": {
            "police": { "type": "boolean" },
            "premier": { "type": "boolean" }
          }
        }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile document identified by Firebase Auth UID."
    },
    "/incidents/{incidentId}": {
      "schema": "SafetyIncident",
      "description": "Global log of all safety incidents for dispatch monitoring."
    }
  }
}
